# ============================================================================
# MediQueue Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.
# ============================================================================

# Supabase Configuration
# Get these from: https://app.supabase.com → Settings → API
SUPABASE_URL=SUPABASE_PROJECT_URL
SUPABASE_KEY=SUPABASE_ANON_KEY

# JWT Configuration
# For local development, you can use any random string.
# For production, use the JWT Secret from Supabase → Settings → API
JWT_SECRET_KEY=JWT_SECRET_KEY_HERE
JWT_ALGORITHM=HS256

# Next.js Web Dashboard (optional, for local development)
NEXT_PUBLIC_SUPABASE_URL=SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=UPABASE_ANON_KEY
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Flutter Mobile App (configured in code, not via .env)
# See: mobile_app/lib/core/config.dart
